---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" sideBarActiveItemID="about">
  <div class="pb-12 mt-5">
    <div class="text-3xl w-full font-bold mb-5">About</div>
    <div class="prose prose-lg max-w-none">
      <p>
        I'm Ken Rhodes, a software developer based in Saint Paul, Minnesota.
        I build open-source tools for communities, with a focus on civic engagement
        and local coordination.
      </p>
      <p>
        The name "impossible fork" comes from a lifelong fascination with optical
        illusions -- the Blivet (also known as the Devil's Tuning Fork or the
        "poiuyt"), the Penrose triangle, Escher's impossible staircases. Objects
        that can't exist but look like they should.
      </p>
      <p>
        All of my projects are open source under the MIT license. If you're working
        on something similar or want to deploy one of these tools in your community,
        get in touch.
      </p>

      <h3>Elsewhere</h3>
      <ul>
        <li><a href="https://bsky.app/profile/knrhds.com" target="_blank">BlueSky (@knrhds.com)</a></li>
        <li><a href="https://github.com/keenrodent" target="_blank">GitHub (keenrodent)</a></li>
      </ul>

      <h3>Contact</h3>
      <p>
        <a href="mailto:k@knrhds.com">k@knrhds.com</a>
      </p>
    </div>
  </div>
</BaseLayout>
