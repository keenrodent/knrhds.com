---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-2">Current Projects</div>
    <p class="text-base-content/70 mb-5">
      Open-source tools for communities. All projects are MIT licensed.
    </p>
  </div>

  <HorizontalCard
    title="local-cleanup"
    img="/local-cleanup.webp"
    desc="Volunteer coordination for neighborhood cleanup. Report spots that need attention, add tasks (litter, weeding, brush clearing), claim work, and mark it done. Built for Saint Paul, MN but deployable by any community."
    url="https://cleanup.knrhds.com"
    badge="LIVE"
  />

  <div class="divider my-0"></div>

  <div class="mt-8">
    <p class="text-base-content/50 italic">More projects coming soon.</p>
  </div>
</BaseLayout>
