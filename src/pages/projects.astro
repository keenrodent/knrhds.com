---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-2">Current Projects</div>
    <p class="text-base-content/70 mb-5">
      Open-source tools for communities. All projects are MIT licensed.
    </p>
  </div>

  <HorizontalCard
    title="local-cleanup"
    img="/post_img.webp"
    desc="Volunteer coordination for neighborhood cleanup. Identify trashy roadsides and public spaces, sign up to clean them, and report when you're done. Built for Saint Paul, MN but designed to be deployable by any community. Uses Leaflet + OpenStreetMap for mapping, Cloudflare for hosting and API."
    url="https://github.com/keenrodent/local-cleanup"
    badge="IN DEV"
  />

  <div class="divider my-0"></div>

  <div class="mt-8">
    <p class="text-base-content/50 italic">More projects coming soon.</p>
  </div>
</BaseLayout>
