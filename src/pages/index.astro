---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-5xl font-bold">Ken Rhodes</div>
    <div class="text-3xl py-3 font-bold text-base-content/70">Civic tech and personal projects</div>
    <div class="py-2">
      <text class="text-lg">
        I build tools for communities. Based in Saint Paul, Minnesota,
        working on open-source projects that help neighbors coordinate and take action locally.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn btn-primary" href="https://bsky.app/profile/knrhds.com" target="_blank">
        BlueSky
      </a>
      <a href="https://github.com/keenrodent" target="_blank" class="btn btn-outline btn-primary ml-5">
        GitHub
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Projects</div>
  </div>

  <HorizontalCard
    title="local-cleanup"
    img="/post_img.webp"
    desc="Volunteer coordination for neighborhood cleanup. Report trashy spots, sign up to clean them, mark them done. Open source, deployable by any community."
    url="https://github.com/keenrodent/local-cleanup"
    badge="IN DEV"
  />
</BaseLayout>
